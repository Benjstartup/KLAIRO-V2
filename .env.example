# ─────────────────────────────────────────────────────────────────────────────
# Klairo — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local:   postgresql://user:password@localhost:5432/klairo
# Neon:    https://neon.tech — free tier available
# Supabase: https://supabase.com — free tier available
DATABASE_URL="postgresql://user:password@localhost:5432/klairo"

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 33
AUTH_SECRET=""

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://yourdomain.com/api/auth/callback/github (prod)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Observability — Phase 0 stubs, wire up when ready ────────────────────────
# Sentry: https://sentry.io
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"

# ── Analytics — Phase 0 stubs, wire up when ready ────────────────────────────
# PostHog: https://posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Billing — Phase 0 stubs, wire up when ready ──────────────────────────────
# Stripe: https://stripe.com
# STRIPE_SECRET_KEY=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""
